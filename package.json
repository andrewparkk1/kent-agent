{
  "name": "kent-agent",
  "version": "0.1.1",
  "description": "Personal AI agent that runs on your Mac",
  "repository": {
    "type": "git",
    "url": "https://github.com/andrewparkk1/kent-agent"
  },
  "homepage": "https://github.com/andrewparkk1/kent-agent",
  "module": "cli/index.ts",
  "type": "module",
  "files": [
    "dist/"
  ],
  "bin": {
    "kent": "./dist/index.js"
  },
  "scripts": {
    "start": "bun run cli/index.ts",
    "dev": "bun run cli/index.ts",
    "kent": "bun run cli/index.ts",
    "init": "bun run cli/index.ts init",
    "daemon:start": "bun run cli/index.ts daemon start",
    "daemon:stop": "bun run cli/index.ts daemon stop",
    "daemon:status": "bun run cli/index.ts daemon status",
    "sync": "bun run cli/index.ts sync",
    "build": "bun build ./cli/index.ts --target bun --minify --outdir ./dist --entry-naming index.js --external react-devtools-core --banner '#!/usr/bin/env bun'",
    "prepublishOnly": "bun run build",
    "typecheck": "tsc --noEmit",
    "cleanup": "rm -rf ~/.kent"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.14"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@mariozechner/pi-agent-core": "^0.63.1",
    "@mariozechner/pi-ai": "^0.63.1",
    "@sinclair/typebox": "^0.34.49",
    "@types/react-dom": "^19.2.3",
    "better-sqlite3-multiple-ciphers": "^12.8.0",
    "ink": "^6.8.0",
    "ink-spinner": "^5.0.0",
    "kysely": "^0.28.15",
    "kysely-bun-sqlite": "^0.4.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "trustedDependencies": [
    "better-sqlite3-multiple-ciphers",
    "sharp"
  ]
}
