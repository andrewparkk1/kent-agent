# Convex environment variables
# Set these in the Convex dashboard (Settings > Environment Variables)
# or in a local .env file for `convex dev`

# Telegram bot — get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
# Random secret string to verify webhook requests
TELEGRAM_WEBHOOK_SECRET=

# E2B — get from https://e2b.dev
E2B_API_KEY=
# Defaults to "andysampark/kent-agent" if not set
E2B_TEMPLATE_ID=

# OpenAI — for embedding generation
OPENAI_API_KEY=
