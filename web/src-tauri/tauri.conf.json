{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Kent",
  "version": "0.1.0",
  "identifier": "com.kent.desktop",
  "build": {
    "frontendDist": "../dist-bundle",
    "devUrl": "http://localhost:19456",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "windows": [
      {
        "title": "Kent",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/andrewparkk1/kent-agent/releases/latest/download/latest.json"
      ],
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJFNTM2NUU2RjgyRTE2NzcKUldSM0ZpNzQ1bVZUdnYzbkRBKzBlc2pOYVF3S0ZRUS9hWmZqTXhlclBwNmpyQXk3MW04cHN0RVgK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/kent-server",
      "binaries/kent-daemon",
      "binaries/kent-agent"
    ],
    "resources": {
      "../dist-bundle": "dist-bundle"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "13.0"
    }
  }
}
