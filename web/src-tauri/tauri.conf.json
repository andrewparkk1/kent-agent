{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Kent",
  "version": "0.1.0",
  "identifier": "com.kent.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "title": "Kent",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/kent-server",
      "binaries/kent-daemon",
      "binaries/kent-agent"
    ],
    "resources": {
      "dist-bundle": "dist-bundle"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "13.0"
    }
  }
}
